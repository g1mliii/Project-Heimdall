{
  "name": "@heimdall/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Heimdall design system — tokens + React primitives. Single source of truth for UI.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./adherence": "./adherence.oxlintrc.json"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-assets.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "eslint": "10.4.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vitest": "4.1.7"
  }
}
