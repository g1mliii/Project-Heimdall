# ─── Postgres (Neon) ──────────────────────────────────────────────
# Pooled connection string from the Neon dashboard.
DATABASE_URL="postgresql://user:password@host.neon.tech/heimdall?sslmode=require"
# Optional direct, migration-owner connection. Production should grant DDL to
# this role only; the web runtime uses the least-privilege DATABASE_URL role.
MIGRATION_DATABASE_URL=""
# Per-process Postgres pool/query guardrails.
DATABASE_POOL_MAX="5"
DATABASE_STATEMENT_TIMEOUT_MS="15000"
DATABASE_QUERY_TIMEOUT_MS="20000"

# ─── Cloudflare R2 (raw frame Parquet + video exports) ────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="heimdall-runs"
# Public/base URL used to read objects back (custom domain or r2.dev).
R2_PUBLIC_BASE_URL=""

# ─── Clerk (auth, Phase 8 §20.1) ───────────────────────────────────
# Leave every var in this block blank to stay anonymous-only (dev/CI default).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Points auth.protect() (proxy.ts) at our styled pages, not Clerk's hosted
# account-portal sign-in — without these, a protected-route redirect goes to
# https://<instance>.accounts.dev/sign-in instead of /sign-in.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
# Svix signing secret for POST /api/webhooks/clerk (Clerk dashboard > Webhooks).
# The route fails closed (503) while this is blank — never accepts unsigned events.
CLERK_WEBHOOK_SIGNING_SECRET=""
# CSV of Clerk user ids promote-only bootstrapped to the admin role.
CLERK_ADMIN_USER_IDS=""
# Multiplier applied to the per-IP hourly limits below when the requester is signed in.
RATE_LIMIT_AUTHED_MULTIPLIER="3"

# ─── Client signature verification (tamper-evidence, NOT a security wall) ──
# Public key the API uses to record signature_valid on uploads.
# Base64-encoded SPKI Ed25519 public key; leave blank to skip verification.
HEIMDALL_SIGNING_PUBLIC_KEY=""

# ─── Ingest API (Phase 4) ─────────────────────────────────────────
# Bearer token for POST /api/internal/jobs/drain (platform cron / manual kick).
# Generate: openssl rand -base64 32
INTERNAL_JOBS_TOKEN=""
# Per-IP fixed-window rate limits (requests per hour). Defaults apply if unset.
RATE_LIMIT_CREATE_RUNS_PER_HOUR="30"
RATE_LIMIT_FINALIZE_PER_HOUR="60"
RATE_LIMIT_DELETE_PER_HOUR="20"
RATE_LIMIT_SEARCH_PER_HOUR="600"
RATE_LIMIT_CLAIM_PER_HOUR="20"
RATE_LIMIT_CREATE_REPORT_PER_HOUR="20"
# Never trust forwarding headers unless the deployment's origin firewall
# guarantees every request arrived through this proxy. Production behind
# Cloudflare should set "cloudflare"; local development stays conservative.
RATE_LIMIT_TRUSTED_PROXY="none"

# ─── ClickHouse (Phase 12 — analytics; leave blank until then) ────
CLICKHOUSE_URL=""
CLICKHOUSE_USER=""
CLICKHOUSE_PASSWORD=""
