# ─── Postgres (Neon) ──────────────────────────────────────────────
# Pooled connection string from the Neon dashboard.
DATABASE_URL="postgresql://user:password@host.neon.tech/heimdall?sslmode=require"
# Per-process Postgres pool/query guardrails.
DATABASE_POOL_MAX="5"
DATABASE_STATEMENT_TIMEOUT_MS="15000"
DATABASE_QUERY_TIMEOUT_MS="20000"

# ─── Cloudflare R2 (raw frame Parquet + video exports) ────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="heimdall-runs"
# Public/base URL used to read objects back (custom domain or r2.dev).
R2_PUBLIC_BASE_URL=""

# ─── Clerk (auth) ─────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# ─── Client signature verification (tamper-evidence, NOT a security wall) ──
# Public key the API uses to record signature_valid on uploads.
# Base64-encoded SPKI Ed25519 public key; leave blank to skip verification.
HEIMDALL_SIGNING_PUBLIC_KEY=""

# ─── Ingest API (Phase 4) ─────────────────────────────────────────
# Bearer token for POST /api/internal/jobs/drain (platform cron / manual kick).
# Generate: openssl rand -base64 32
INTERNAL_JOBS_TOKEN=""
# Per-IP fixed-window rate limits (requests per hour). Defaults apply if unset.
RATE_LIMIT_CREATE_RUNS_PER_HOUR="30"
RATE_LIMIT_FINALIZE_PER_HOUR="60"
RATE_LIMIT_DELETE_PER_HOUR="20"

# ─── ClickHouse (Phase 12 — analytics; leave blank until then) ────
CLICKHOUSE_URL=""
CLICKHOUSE_USER=""
CLICKHOUSE_PASSWORD=""
